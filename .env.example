# Copy to .env at repo root and server/.env as needed (server loads ../../.env then server/.env).

# API port (must match Vite proxy — default 4000)
PORT=4000
JWT_SECRET=change-me-at-least-16-chars

# Comma-separated browser origins for CORS + Socket.IO (production)
# APP_ORIGIN=https://app.theoove.com,https://theoove.com

# --- Email (Resend) ---
# If unset, signup OTP is returned in the API response (dev only) and logged to the console.
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@contact.theoove.com

# --- Optional admin ---
ADMIN_PRIMARY_EMAIL=you@company.com

# --- Deposit proof uploads (S3-compatible: AWS S3, Cloudflare R2, MinIO) ---
# When all bucket + creds + public URL are set, the app uses presigned PUT for real proof files.
S3_DEPOSIT_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public URL where objects are readable (R2 public bucket URL or CDN), no trailing slash
S3_PUBLIC_BASE_URL=
# R2 / MinIO only — omit for AWS
S3_ENDPOINT=

# --- Local-only flags (never in production) ---
# DEV_PASSWORDLESS_SESSION=true
# OOVE_DEMO_KYC=true
