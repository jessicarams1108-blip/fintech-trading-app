# =============================================================================
# Local development (repo root + server/.env)
# =============================================================================

# API port — must match Vite proxy in web/vite.config.ts (default 4000)
PORT=4000

# Postgres (required for server)
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/trading_app

# Auth (required, min 16 characters)
JWT_SECRET=change-me-at-least-16-characters

# Comma-separated browser origins for CORS + Socket.IO (production)
# APP_ORIGIN=https://your-app.vercel.app,https://theoove.com

# Admin gate (comma-separated; both can use admin console)
ADMIN_EMAILS=Hardewusi@gmail.com,sheiserishadanyellejohnson@gmail.com
# Legacy single-email override (optional if ADMIN_EMAILS is set)
ADMIN_PRIMARY_EMAIL=you@company.com

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Deposit proof uploads (S3-compatible) ---
S3_DEPOSIT_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_ENDPOINT=

# Optional: CoinMarketCap Pro API key — enables live price, 24h %, market cap, and volume from CMC on /api/market/asset-overview (chart history still uses CoinGecko).
# https://coinmarketcap.com/api/
# COINMARKETCAP_API_KEY=


# =============================================================================
# Vercel (frontend only) — set in Vercel Project → Settings → Environment Variables
# =============================================================================

# Public URL of your deployed API (Railway, Render, etc.). No trailing slash.
# Example: https://fintech-trading-app-production.up.railway.app
VITE_API_URL=

# Admin emails in UI (comma-separated; must match server ADMIN_EMAILS)
VITE_ADMIN_EMAILS=Hardewusi@gmail.com,sheiserishadanyellejohnson@gmail.com
VITE_ADMIN_PRIMARY_EMAIL=

# =============================================================================
# Railway / Render (API host) — set on the backend service, not Vercel
# =============================================================================
# DATABASE_URL=   (from hosted Postgres)
# JWT_SECRET=
# APP_ORIGIN=https://your-app.vercel.app
# PORT=           (injected by host — do not hardcode)
